{
  "name": "@~/identite-proconnect",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#src/*": "./src/*/index.ts"
  },
  "exports": {
    "./database/seed/*": {
      "default": "./src/database/seed/*.ts"
    },
    "./*": {
      "default": "./src/*/index.ts"
    }
  },
  "scripts": {
    "introspect": "bun x drizzle introspect:pg",
    "migrate": "bun run bin/migrate.ts",
    "seed": "bun run bin/seed.ts",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@proconnect-gouv/proconnect.api_entreprise": "2.2.0",
    "@proconnect-gouv/proconnect.core": "1.0.0",
    "@proconnect-gouv/proconnect.identite": "5.0.0",
    "@proconnect-gouv/proconnect.identite.database": "1.4.0",
    "@proconnect-gouv/proconnect.insee": "2.0.0",
    "consola": "3.4.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.14",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@~/config.typescript": "workspace:*",
    "@electric-sql/pglite": "0.3.16",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.9"
  }
}
